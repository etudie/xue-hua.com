---
import BaseLayout from "../layouts/BaseLayout.astro";
import LogoCloud from "../components/LogoCloud.astro";
import Offer from "../components/MainOffer.astro";
import Closing from "../components/Closing.astro";
import ARROW_RIGHT from "../assets/images/icons/arrow-right.svg";
import FIREFLY from "../assets/hero-firefly.mp4";
---

<!-- TODO: Snap scroll, and make sure face is never covered-->
<BaseLayout backgroundColor="bg-black" title="Home">
  <!-- PANEL 1 -->
  <!-- panel 1 container, for sizing -->
  <div class="flex h-svh w-full bg-black">
    <!-- hero video -->
    <div class="absolute flex size-full items-center overflow-hidden">
      <video
        aria-hidden="true"
        autoplay
        class="h-8/10 object-cover opacity-80"
        id="hero-video"
        loop
        muted
        playsinline
        preload="auto"
      >
        <source src={FIREFLY} type="video/mp4" />
        Your browser does not support the video tag.
      </video>
      <div class="hero-overlay-container">
        <div class="hero-overlay-top"></div>
        <div class="hero-overlay-bottom"></div>
      </div>
    </div>

    <!--hero content container-->
    <div class="hero flex flex-col gap-8">
      <!-- hero content-->
      <section class="hero-content flex-1 flex-col justify-between px-8 text-center">
        <!--title-->
        <div class="flex flex-1 flex-col justify-center gap-8">
          <h1 class="hero-text font-semibold" data-text="Engineering Purpose">
            <span class="blur-[1.3px]"> Engineering Purpose</span>
          </h1>

          <h6 class="hero-subtitle leading-relaxed opacity-80 text-shadow-md">
            I make AI click for your people.<br />Clear systems. Real results.
          </h6>
        </div>

        <!--CTA buttons-->
        <div class="flex w-full flex-col gap-8">
          <button class="btn btn-md btn-primary"> Schedule a Workshop</button>
          <button class="btn text-neutral-light btn-outline btn-md backdrop-blur-md">
            Explore Resources</button
          >
        </div>
      </section>

      <!--down arrow-->
      <div class="text-base-content/80 flex w-full items-center justify-center">
        <svg
          class="size-6 animate-bounce"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          viewBox="0 0 24 24"
          xmlns="http://www.w3.org/2000/svg"
        >
          <path
            d="M19.5 13.5 12 21m0 0-7.5-7.5M12 21V3"
            stroke-linecap="round"
            stroke-linejoin="round"></path>
        </svg>
      </div>
    </div>
  </div>

  <!-- PANEL 2 -->
  <div class="bg-neutral-dark flex h-svh w-full flex-col justify-between gap-8 p-6">
    <div class="divider divider-start">About the Work</div>

    <div class="stats stats-vertical lg:stats-horizontal w-full flex-1">
      <div class="stat">
        <div class="stat-title">Clarity over AI complexity</div>
        <div class="stat-value text-primary text-center text-2xl">100+ sessions</div>
      </div>

      <div class="stat">
        <div class="stat-title">Execution for the overwhelmed</div>
        <div class="stat-value text-secondary text-center text-2xl">50+ engineers</div>
      </div>

      <div class="stat">
        <div class="stat-title">Only clear systems that work</div>
        <div class="stat-value text-center text-2xl">0% AI theater</div>
      </div>
    </div>
    <LogoCloud />

    <div class="flex justify-end">
      <button class="btn btn-soft btn-md btn-primary"
        >See my work <img alt="right arrow" src={ARROW_RIGHT.src} />
      </button>
    </div>
  </div>

  <!-- PANEL 3 -->
  <div class="bg-neutral text-neutral-content flex h-svh w-full flex-col justify-between p-6">
    <div class="flex w-full flex-col">
      <div class="divider divider-start divider-accent">Work with Xue</div>
    </div>
    <Offer />
  </div>

  <!-- PANEL 4 -->
  <div class="bg-neutral-light text-neutral-accent-content flex h-svh w-full flex-col gap-8 p-6">
    <div class="flex w-full flex-col">
      <div class="divider divider-start after:bg-base-100">Explore Content</div>
    </div>
    <Closing />
  </div>
</BaseLayout>

<script src="../scripts/IndexScript.js"></script>
