---
import BaseLayout from "../layouts/BaseLayout.astro";
import "../styles/styles.css";
import LogoCloud from "../components/LogoCloud.astro";
import Offer from "../components/MainOffer.astro";
import Closing from "../components/Closing.astro";
import ARROW_RIGHT from "../assets/images/icons/arrow-right.svg?raw";
import FIREFLY from "../assets/hero-firefly.mp4";
---

<!-- TODO: Snap scroll, and make sure face is never covered-->
<BaseLayout title="Home" backgroundColor="bg-black">
  <!-- PANEL 1 -->
  <div class="hero h-svh bg-black">
    <div
      class="absolute flex h-svh w-full items-end overflow-hidden "
    >
      <video
        autoplay
        loop
        muted
        playsinline
        preload="auto"
        aria-hidden="true"
        class="flex-1 h-8/10 mask-t-from-90% mask-b-from-80% opacity-80 object-cover"
        id="hero-video"
      >
        <source src={FIREFLY} type="video/mp4" />
        Your browser does not support the video tag.
      </video>
    </div>
    <!--bg-[url(../assets/images/hero/hero-main.webp)] saturate-120-->
    <!--<div class="hero-overlay"></div>-->
    <!--<div class="hero-overlay-gradient"></div>-->
    <!--<div class="hero-overlay-top"></div>-->
    <!--<Hero />-->
    <section
      class="hero-content h-full flex-col justify-between px-8 py-24 text-center"
    >
      <div class="flex max-w-md flex-1 flex-col justify-center gap-8">
        <h1 class="hero-text font-semibold" data-text="Engineering Purpose">
          <span class="blur-[1.3px]"> Engineering Purpose</span>
        </h1>

        <h6 class="hero-subtitle leading-relaxed opacity-80 text-shadow-md">
          I make AI click for your people.<br />Clear systems. Real results.
        </h6>
        <p class="size-1/3"></p>
      </div>
      <div class="flex w-full flex-col gap-6">
        <button class="btn btn-primary btn-md"> Schedule a Workshop</button>
        <button
          class="btn btn-md btn-outline text-neutral-light backdrop-blur-md"
        >
          Explore Resources</button
        >
      </div>
    </section>
    <section
      class="text-base-content/80 flex h-full w-full items-end justify-center pb-6"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        fill="none"
        viewBox="0 0 24 24"
        stroke-width="1.5"
        stroke="currentColor"
        class="size-6 animate-bounce"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M19.5 13.5 12 21m0 0-7.5-7.5M12 21V3"></path>
      </svg>
    </section>
  </div>

  <!-- PANEL 2 -->
  <div
    class="flex bg-neutral-dark h-svh w-full flex-col justify-between gap-8 p-6"
  >
      <div class="divider divider-start">About the Work</div>

    <div
      class="stats stats-vertical lg:stats-horizontal w-full flex-1"
    >
      <div class="stat">
        <div class="stat-title">Clarity over AI complexity</div>
        <div class="stat-value text-primary text-center text-2xl">100+ sessions</div>
      </div>

      <div class="stat">
        <div class="stat-title">Execution for the overwhelmed</div>
        <div class="stat-value text-secondary text-center text-2xl">50+ engineers</div>
      </div>

      <div class="stat">
        <div class="stat-title">Only clear systems that work</div>
        <div class="stat-value text-center text-2xl">0% AI theater</div>
      </div>
    </div>
    <LogoCloud />

    <div class="flex justify-end">
      <button class="btn btn-soft btn-primary btn-md"
        >See my work <Fragment set:html={ARROW_RIGHT} />
      </button>
    </div>
  </div>

  <!-- PANEL 3 -->
  <div
    class="bg-neutral text-neutral-content flex min-h-[calc(100svh-4rem)] w-full flex-col justify-between p-6"
  >
    <div class="flex w-full flex-col">
      <div class="divider divider-start divider-accent">Work with Xue</div>
    </div>
    <Offer />
  </div>

  <!-- PANEL 4 -->
  <div
    class="bg-neutral-light text-neutral-accent-content flex min-h-[calc(100svh-4rem)] w-full flex-col gap-8 p-6"
  >
    <div class="flex w-full flex-col">
      <div class="divider divider-start after:bg-base-100">Explore Content</div>
    </div>
    <Closing />
  </div>
</BaseLayout>

<script>
  const video = document.getElementById("hero-video");

  if (video instanceof HTMLVideoElement) {
    video.muted = true;
    video.playsInline = true;
    video.playbackRate = 0.7; // slower than normal

    const tryPlay = async () => {
      try { await video.play(); } catch {}
    };

    // Try immediately
    tryPlay();

    // Retry once on first user interaction (common iOS behavior)
    const once = () => { tryPlay(); window.removeEventListener("touchstart", once); window.removeEventListener("click", once); };
    window.addEventListener("touchstart", once, { passive: true });
    window.addEventListener("click", once, { passive: true });
  }
</script>
