---
import { FOOTER } from "../constants/strings/footer.strings";
---

<footer class="footer bg-base-200 text-base-content sm:footer-horizontal p-10">
  <aside class="flex w-full flex-col items-center">
    <small>{FOOTER.copyright.label}</small>
  </aside>
  {
    FOOTER.sections.map((section) => (
      <nav class="flex w-full flex-col items-center">
        <h6 class="footer-title">{section.label}</h6>
        {section.content.map((item) => (
          <a class="link link-hover" href={item.href}>
            {item.label}
          </a>
        ))}
      </nav>
    ))
  }
</footer>
