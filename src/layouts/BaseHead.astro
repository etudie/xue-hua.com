---
import { mergeSeo, toAbsoluteUrl } from "../utils/seo";
import { SEO_DEFAULTS } from "../constants/strings/seo.strings.ts";

type Props = {
  seo?: import("../utils/seo").SeoMeta;
};

const { seo: seoOverrides = {} } = Astro.props;

const resolvedSeo = mergeSeo(SEO_DEFAULTS, {
  ...seoOverrides,
  canonical:
    seoOverrides.canonical ??
    (Astro.site ? new URL(Astro.url.pathname, Astro.site).toString() : ""),
});

// Make images absolute for best compatibility
const ogImage = toAbsoluteUrl(Astro.site, resolvedSeo.openGraph.image);
const twImage = toAbsoluteUrl(Astro.site, resolvedSeo.twitter.image);
---

<head>
  <meta charset="utf-8" />
  <meta content="width=device-width, initial-scale=1.0" name="viewport" />

  <title>{resolvedSeo.title}</title>
  <meta content={resolvedSeo.description} name="description" />
  <meta content={resolvedSeo.robots} name="robots" />

  {resolvedSeo.canonical && <link href={resolvedSeo.canonical} rel="canonical" />}

  <!-- Open Graph -->
  <meta content={resolvedSeo.openGraph.title} property="og:title" />
  <meta content={resolvedSeo.openGraph.description} property="og:description" />
  <meta content={resolvedSeo.openGraph.type} property="og:type" />
  {ogImage && <meta content={ogImage} property="og:image" />}

  <!-- Twitter -->
  <meta content={resolvedSeo.twitter.card} name="twitter:card" />
  <meta content={resolvedSeo.twitter.title} name="twitter:title" />
  <meta content={resolvedSeo.twitter.description} name="twitter:description" />
  {twImage && <meta content={twImage} name="twitter:image" />}
</head>
